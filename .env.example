HOST=0.0.0.0
PORT=3100
PUBLIC_BASE_URL=http://localhost:3100
BRIDGE_NAME=MCP Auth Server
UPSTREAM_PROVIDER_NAME=Swiggy

# Optional bearer gate for internal MCP clients.
# Leave empty if you are already protecting the service with VPN / reverse proxy auth.
INTERNAL_BEARER_TOKEN=

# Optional comma-separated allowlist. If empty, every upstream tool is proxied.
MCP_ALLOWED_TOOLS=

# Generic upstream configuration.
# Use either a single endpoint via UPSTREAM_MCP_URL or multiple endpoints via MCP_UPSTREAM_ENDPOINTS_JSON.
UPSTREAM_MCP_URL=
UPSTREAM_ENDPOINT_NAME=
UPSTREAM_ENDPOINT_KEY=
MCP_UPSTREAM_ENDPOINTS_JSON=
OAUTH_SCOPE=mcp:tools mcp:resources mcp:prompts
OAUTH_CLIENT_NAME=Swiggy MCP Auth Bridge
TOKEN_STORE_PATH=./data/oauth-tokens.json
UPSTREAM_TIMEOUT_MS=30000

# Backward-compatible Swiggy preset aliases are still supported.
# SWIGGY_FOOD_URL=https://mcp.swiggy.com/food
# SWIGGY_INSTAMART_URL=https://mcp.swiggy.com/im
# SWIGGY_DINEOUT_URL=https://mcp.swiggy.com/dineout
# SWIGGY_SCOPE=mcp:tools mcp:resources mcp:prompts
# SWIGGY_CLIENT_NAME=Swiggy MCP Auth Bridge
