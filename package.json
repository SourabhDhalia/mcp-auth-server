{
  "name": "mcp-auth-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OAuth-capable MCP bridge for exposing a simpler internal MCP endpoint in front of protected upstream MCP servers.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/SourabhDhalia/mcp-auth-server#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SourabhDhalia/mcp-auth-server.git"
  },
  "bugs": {
    "url": "https://github.com/SourabhDhalia/mcp-auth-server/issues"
  },
  "keywords": [
    "mcp",
    "oauth",
    "model-context-protocol",
    "bridge",
    "auth",
    "typescript"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.8",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
