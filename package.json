{
  "name": "swiggy-mcp-oauth-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Internal MCP bridge that completes Swiggy OAuth once and exposes approved MCP access over Streamable HTTP.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.8",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
